        <mxCell id="9WJ9yf6WJ3oW-EcoJWDf-40" value="&lt;b&gt;&lt;font color=&quot;#ff3333&quot; style=&quot;font-size: 13px;&quot;&gt;FLV一帧大小 = Header(11字节) +&lt;/font&gt;&lt;/b&gt;&lt;font style=&quot;font-size: 14px;&quot; color=&quot;#ff3333&quot;&gt;&lt;b&gt;Tag&amp;nbsp;Data&amp;nbsp;(可变长度)&lt;font style=&quot;font-size: 14px;&quot;&gt;&amp;nbsp;+&lt;/font&gt;&lt;/b&gt;&lt;/font&gt;&lt;b&gt;&lt;font color=&quot;#ff3333&quot; style=&quot;font-size: 13px;&quot;&gt;&amp;nbsp;&lt;/font&gt;&lt;/b&gt;&lt;font color=&quot;#ff3333&quot;&gt;&lt;span style=&quot;font-size: 13px;&quot;&gt;&lt;b&gt;Previous Tag Size (4 字节)&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
