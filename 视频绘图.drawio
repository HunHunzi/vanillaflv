        <mxCell id="JGCSjJwZG7jfOkzR3wHW-3" value="&lt;div style=&quot;color: rgb(252, 252, 250); background-color: rgb(45, 42, 46); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-weight: normal; font-size: 9px; line-height: 122%; white-space: pre;&quot;&gt;&lt;div style=&quot;font-size: 9px; line-height: 122%;&quot;&gt;&lt;span style=&quot;color: rgb(252, 252, 250); font-size: 9px;&quot;&gt;track &lt;/span&gt;&lt;span style=&quot;color: rgb(255, 97, 136); font-size: 9px;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: rgb(252, 252, 250); font-size: 9px;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(147, 146, 147); font-size: 9px;&quot;&gt;{&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 9px; line-height: 122%;&quot;&gt;&lt;span style=&quot;color: rgb(252, 252, 250); font-size: 9px;&quot;&gt;&amp;nbsp; len&lt;/span&gt;&lt;span style=&quot;color: rgb(147, 146, 147); font-size: 9px;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(252, 252, 250); font-size: 9px;&quot;&gt; dataLength&lt;/span&gt;&lt;span style=&quot;color: rgb(147, 146, 147); font-size: 9px;&quot;&gt;,&lt;/span&gt;&lt;span style=&quot;color: rgb(252, 252, 250); font-size: 9px;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(114, 112, 114); font-style: italic; font-size: 9px;&quot;&gt;// 视频数据总长度，以字节为单位&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 9px; line-height: 122%;&quot;&gt;&lt;span style=&quot;color: rgb(252, 252, 250); font-size: 9px;&quot;&gt;&amp;nbsp; naluCnt&lt;/span&gt;&lt;span style=&quot;color: rgb(147, 146, 147); font-size: 9px;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(252, 252, 250); font-size: 9px;&quot;&gt; nalus&lt;/span&gt;&lt;span style=&quot;color: rgb(147, 146, 147); font-size: 9px;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: rgb(120, 220, 232); font-size: 9px;&quot;&gt;length&lt;/span&gt;&lt;span style=&quot;color: rgb(147, 146, 147); font-size: 9px;&quot;&gt;,&lt;/span&gt;&lt;span style=&quot;color: rgb(252, 252, 250); font-size: 9px;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(114, 112, 114); font-style: italic; font-size: 9px;&quot;&gt;// NALU（网络抽象层单元）的数量&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 9px; line-height: 122%;&quot;&gt;&lt;span style=&quot;color: rgb(252, 252, 250); font-size: 9px;&quot;&gt;&amp;nbsp; isAV01&lt;/span&gt;&lt;span style=&quot;color: rgb(147, 146, 147); font-size: 9px;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(252, 252, 250); font-size: 9px;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(171, 157, 242); font-size: 9px;&quot;&gt;false&lt;/span&gt;&lt;span style=&quot;color: rgb(147, 146, 147); font-size: 9px;&quot;&gt;,&lt;/span&gt;&lt;span style=&quot;color: rgb(252, 252, 250); font-size: 9px;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(114, 112, 114); font-style: italic; font-size: 9px;&quot;&gt;// 标识是否为 AV1 编码，这里为 H.264，所以设置为 false&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 9px; line-height: 122%;&quot;&gt;&lt;span style=&quot;color: rgb(252, 252, 250); font-size: 9px;&quot;&gt;&amp;nbsp; samples&lt;/span&gt;&lt;span style=&quot;color: rgb(147, 146, 147); font-size: 9px;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(252, 252, 250); font-size: 9px;&quot;&gt; samples&lt;/span&gt;&lt;span style=&quot;color: rgb(147, 146, 147); font-size: 9px;&quot;&gt;,&lt;/span&gt;&lt;span style=&quot;color: rgb(252, 252, 250); font-size: 9px;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(114, 112, 114); font-style: italic; font-size: 9px;&quot;&gt;// 样本数据数组，每个样本代表一个视频帧&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 9px; line-height: 122%;&quot;&gt;&lt;span style=&quot;color: rgb(147, 146, 147); font-size: 9px;&quot;&gt;};&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;fontSize=9;" parent="1" vertex="1">
