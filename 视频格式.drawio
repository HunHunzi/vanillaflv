        <mxCell id="sFTBbgv-1wokPd63pDNA-2" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;AVCPacketType&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;" parent="1" vertex="1">
