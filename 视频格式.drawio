          <mxGeometry x="4210" y="-1892" width="40" height="30" as="geometry" />
        </mxCell>
        <mxCell id="4ehvYs4uBC59rccrSoze-12" value="1B" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
