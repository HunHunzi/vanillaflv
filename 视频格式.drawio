          <mxGeometry x="4140" y="-524.36" width="50" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sFTBbgv-1wokPd63pDNA-4" value="1Byte" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
