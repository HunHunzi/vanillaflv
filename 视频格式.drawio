          </mxGeometry>
        </mxCell>
        <mxCell id="Sr-X2rEYAPfRVNXDpDGh-94" value="&lt;div&gt;stsd给出sample的描述信息，这里面包含了在解码阶段需要用到的任意初始化信息，比如 编码 等。对于视频、音频来说，所需要的初始化信息不同，这里以视频为例。&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;aligned(8) abstract class SampleEntry (unsigned int(32) format) extends Box(format){&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; const unsigned int(8)[6] reserved = 0;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; unsigned int(16) data_reference_index;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;// Visual Sequences&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;class VisualSampleEntry(codingname) extends SampleEntry (codingname){&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; unsigned int(16) pre_defined = 0;// 预定义位&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; const unsigned int(16) reserved = 0;// 保留位&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; unsigned int(32)[3] pre_defined = 0;// 预定义位&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; unsigned int(16) width;// 视频宽度&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; unsigned int(16) height;// 视频高度&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; template unsigned int(32) horizresolution = 0x00480000; // 72 dpi&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; template unsigned int(32) vertresolution = 0x00480000; // 72 dpi&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; const unsigned int(32) reserved = 0;// 保留位&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; template unsigned int(16) frame_count = 1;// 一组图像中的帧数&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; string[32] compressorname;// 压缩器名称&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; template unsigned int(16) depth = 0x0018;// 24-bit color&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; int(16) pre_defined = -1;// 预定义位&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;// AudioSampleEntry、HintSampleEntry 定义略过&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;aligned(8) class SampleDescriptionBox (unsigned int(32) handler_type) extends FullBox(&#39;stsd&#39;, 0, 0){&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; int i ;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; unsigned int(32) entry_count;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; for (i = 1 ; i u entry_count ; i++) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; switch (handler_type){&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; case ‘soun’: // for audio tracks&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; AudioSampleEntry();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; break;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; case ‘vide’: // for video tracks&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;VisualSampleEntry();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;break;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; case ‘hint’: // Hint track&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;HintSampleEntry();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;break;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="Sr-X2rEYAPfRVNXDpDGh-82" vertex="1">
          <mxGeometry x="10" y="60" width="660" height="620" as="geometry" />
        </mxCell>
        <mxCell id="Sr-X2rEYAPfRVNXDpDGh-83" value="&lt;span style=&quot;font-weight: 400;&quot;&gt;stsc-Sample To Chunk Table&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;stsc：每个thunk中包含几个sample；&lt;/span&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="swimlane;whiteSpace=wrap;html=1;startSize=40;align=left;" parent="1" vertex="1">
          <mxGeometry x="537.1800000000001" y="-1230" width="589" height="280" as="geometry">
            <mxRectangle x="837.1800000000001" y="-1220" width="289" height="40" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="Sr-X2rEYAPfRVNXDpDGh-99" value="&lt;div&gt;stsc&amp;nbsp;&lt;/div&gt;&lt;div&gt;sample 以 chunk 为单位分成多个组。chunk的size可以是不同的，chunk里面的sample的size也可以是不同的。&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;entry_count：有多少个表项（每个表项，包含first_chunk、samples_per_chunk、sample_description_index信息）；&lt;/div&gt;&lt;div&gt;first_chunk：当前表项中，对应的第一个chunk的序号；&lt;/div&gt;&lt;div&gt;samples_per_chunk：每个chunk包含的sample数；&lt;/div&gt;&lt;div&gt;sample_description_index：指向 stsd 中 sample description 的索引值（参考stsd小节）；&lt;/div&gt;&lt;div&gt;aligned(8) class SampleToChunkBox&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; extends FullBox(‘stsc’, version = 0, 0) {&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; unsigned int(32) entry_count;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; for (i=1; i u entry_count; i++) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; unsigned int(32) first_chunk;// 第一个chunk的序号&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; unsigned int(32) samples_per_chunk; // 每个chunk包含的sample数&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; unsigned int(32) sample_description_index;// 指向stsd中sample description的索引值&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="Sr-X2rEYAPfRVNXDpDGh-83" vertex="1">
          <mxGeometry y="40" width="640" height="260" as="geometry" />
        </mxCell>
        <mxCell id="Sr-X2rEYAPfRVNXDpDGh-84" value="&lt;span style=&quot;font-weight: 400;&quot;&gt;stts-Timestamp Table&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;stts: 每个sample的时长；&lt;/span&gt;" style="swimlane;whiteSpace=wrap;html=1;startSize=30;align=left;" parent="1" vertex="1">
          <mxGeometry x="537.1800000000001" y="-674.36" width="549" height="220" as="geometry">
            <mxRectangle x="525.5" y="-1040" width="279" height="30" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="Sr-X2rEYAPfRVNXDpDGh-100" value="stts&#xa;stts包含了DTS到sample number的映射表，主要用来推导每个帧的时长。&#xa;例如：entry_count为3，前250个sample的时长为1000，第251个sample时长为999，第252~283个sample的时长为1000。&#xa;aligned(8) class TimeToSampleBox extends FullBox(’stts’, version = 0, 0) {&#xa;    unsigned int(32)  entry_count;// 有多少个表项&#xa;    int i;&#xa;    for (i=0; i &lt; entry_count; i++) {&#xa;        unsigned int(32)  sample_count;// 连续的sample数&#xa;        unsigned int(32)  sample_delta;// 这些sample的时间戳增量，以time_scale为单位&#xa;    }&#xa;}" style="text;whiteSpace=wrap;" parent="Sr-X2rEYAPfRVNXDpDGh-84" vertex="1">
          <mxGeometry x="-1" y="30" width="560" height="200" as="geometry" />
        </mxCell>
        <mxCell id="Sr-X2rEYAPfRVNXDpDGh-85" value="&lt;span style=&quot;font-weight: 400;&quot;&gt;stsz-Sample Size Table&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;stsz每个sample的大小（字节），根据 sample_size 字段，可以知道当前track包含了多少个sample（或帧）&lt;/span&gt;" style="swimlane;whiteSpace=wrap;html=1;startSize=40;align=left;" parent="1" vertex="1">
          <mxGeometry x="535" y="-419.99999999999994" width="1100" height="400" as="geometry">
            <mxRectangle x="860" y="-838.42" width="520" height="40" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="Sr-X2rEYAPfRVNXDpDGh-102" value="&lt;div&gt;stsz&amp;nbsp;&lt;/div&gt;&lt;div&gt;stsz是sample size box，里面存储了每个sample的大小。如果所有sample的大小都相同，那么可以使用stsz来存储sample的大小。&lt;/div&gt;&lt;div&gt;有两种不同的box类型，stsz、stz2。&lt;/div&gt;&lt;div&gt;stsz&lt;/div&gt;&lt;div&gt;aligned(8) class SampleSizeBox extends FullBox(‘stsz’, version = 0, 0) {&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; unsigned int(32) sample_size; // 默认的sample大小（单位是byte），通常为0。如果sample_size不为0，那么，所有的sample都是同样的大小。如果sample_size为0，那么，sample的大小可能不一样。&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; unsigned int(32) sample_count;// 当前track里面的sample数目。如果 sample_size==0，那么，sample_count 等于下面entry的条目；&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; if (sample_size==0) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; for (i=1; i u sample_count; i++) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; unsigned int(32)&amp;nbsp; entry_size;// 单个sample的大小（如果sample_size==0的话）；&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;stz2&lt;/div&gt;&lt;div&gt;aligned(8) class CompactSampleSizeBox extends FullBox(‘stz2’, version = 0, 0) {&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; unsigned int(24) reserved = 0;// entry表中，每个entry_size占据的位数（bit），可选的值为4、8、16。4比较特殊，当field_size等于4时，一个字节上包含两个entry，高4位为entry[i]，低4位为entry[i+1]；&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; unisgned int(8) field_size; // 等于下面entry的条目；&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; unsigned int(32) sample_count;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; for (i=1; i u sample_count; i++) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; unsigned int(field_size) entry_size;// 单个sample的大小（如果sample_size==0的话）；&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="Sr-X2rEYAPfRVNXDpDGh-85" vertex="1">
          <mxGeometry y="40" width="1100" height="360" as="geometry" />
        </mxCell>
        <mxCell id="Sr-X2rEYAPfRVNXDpDGh-86" value="&lt;span style=&quot;font-weight: 400;&quot;&gt;stco-Chunk Offsets Table&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;stco：thunk在文件中的偏移；&lt;/span&gt;&lt;/div&gt;" style="swimlane;whiteSpace=wrap;html=1;startSize=30;align=left;" parent="1" vertex="1">
          <mxGeometry x="1654" y="-495.24" width="499" height="450" as="geometry">
            <mxRectangle x="520.5" y="-760" width="279" height="30" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="Sr-X2rEYAPfRVNXDpDGh-98" value="&lt;div&gt;stco&amp;nbsp;&lt;/div&gt;&lt;div&gt;chunk在文件中的偏移量。针对小文件、大文件，有两种不同的box类型，分别是stco、co64，它们的结构是一样的，只是字段长度不同。&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;chunk_offset 指的是在文件本身中的 offset，而不是某个box内部的偏移。&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;在构建mp4文件的时候，需要特别注意 moov 所处的位置，它对于chunk_offset 的值是有影响的。有一些MP4文件的 moov 在文件末尾，为了优化首帧速度，需要将 moov 移到文件前面，此时，需要对 chunk_offset 进行改写。&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;# Box Type: ‘stco’, ‘co64’&lt;/div&gt;&lt;div&gt;# Container: Sample Table Box (‘stbl’) Mandatory: Yes&lt;/div&gt;&lt;div&gt;# Quantity: Exactly one variant must be present&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;aligned(8) class ChunkOffsetBox&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; extends FullBox(‘stco’, version = 0, 0) {&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; unsigned int(32) entry_count;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; for (i=1; i u entry_count; i++) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; unsigned int(32)&amp;nbsp; chunk_offset;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;aligned(8) class ChunkLargeOffsetBox&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; extends FullBox(‘co64’, version = 0, 0) {&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; unsigned int(32) entry_count;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; for (i=1; i u entry_count; i++) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; unsigned int(64)&amp;nbsp; chunk_offset;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="Sr-X2rEYAPfRVNXDpDGh-86" vertex="1">
          <mxGeometry y="220" width="470" height="50" as="geometry" />
        </mxCell>
        <mxCell id="Sr-X2rEYAPfRVNXDpDGh-103" value="&lt;div&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;Decoding Time to Sample Box&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;stss:&lt;/span&gt;&lt;span style=&quot;background-color: initial; font-weight: 400;&quot;&gt;包含了DTS到sample number的映射表，主要用来推导每个帧的时长。&lt;/span&gt;&lt;/div&gt;" style="swimlane;whiteSpace=wrap;html=1;startSize=30;align=left;" parent="1" vertex="1">
          <mxGeometry x="537.1800000000001" y="-920" width="562.46" height="210" as="geometry">
            <mxRectangle x="520.5" y="-970" width="462" height="30" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="Sr-X2rEYAPfRVNXDpDGh-101" value="stss&#xa;stss是sync sample box，里面存储的是关键帧的序号。如果视频是I帧编码，那么stss中存储的就是所有帧的序号。如果没有stss，那么所有帧都是关键帧。&#xa;aligned(8) class SyncSampleBox&#xa;   extends FullBox(‘stss’, version = 0, 0) {&#xa;   unsigned int(32)  entry_count;// entry的条目数，可以认为是关键帧的数目；&#xa;   int i;&#xa;   for (i=0; i &lt; entry_count; i++) {&#xa;      unsigned int(32)  sample_number;// 关键帧的序号, 从1开始&#xa;   }&#xa;}" style="text;whiteSpace=wrap;" parent="Sr-X2rEYAPfRVNXDpDGh-103" vertex="1">
          <mxGeometry x="2.4600000000000364" y="30" width="560" height="180" as="geometry" />
        </mxCell>
        <mxCell id="Sr-X2rEYAPfRVNXDpDGh-110" value="" style="shape=curlyBracket;whiteSpace=wrap;html=1;rounded=1;flipH=0;labelPosition=right;verticalLabelPosition=middle;align=left;verticalAlign=middle;flipV=1;" parent="1" vertex="1">
          <mxGeometry x="450" y="-1180" width="20" height="495" as="geometry" />
        </mxCell>
        <mxCell id="gJWx8cU3EQOEuicg33ia-1" value="&lt;b&gt;&lt;font style=&quot;font-size: 13px;&quot; color=&quot;#ff3333&quot;&gt;FLV一帧(Tag)大小 = TagHeader(11字节) +&lt;/font&gt;&lt;/b&gt;&lt;font style=&quot;font-size: 14px;&quot; color=&quot;#ff3333&quot;&gt;&lt;b&gt;Tag&amp;nbsp;Data&amp;nbsp;(可变长度)&amp;nbsp;+&lt;/b&gt;&lt;/font&gt;&lt;b&gt;&lt;font style=&quot;font-size: 13px;&quot; color=&quot;#ff3333&quot;&gt;&amp;nbsp;&lt;/font&gt;&lt;/b&gt;&lt;font color=&quot;#ff3333&quot;&gt;&lt;span style=&quot;font-size: 13px;&quot;&gt;&lt;b&gt;Previous Tag Size (4 字节)&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="5095" y="-1691" width="570" height="30" as="geometry" />
        </mxCell>
        <mxCell id="gJWx8cU3EQOEuicg33ia-2" value="1 字节：Tag 类型（音频 = 8，视频 = 9，脚本 = 18）。&#xa;3 字节：数据大小（Big-Endian 格式）。&#xa;3 字节：时间戳（毫秒，低 24 位）。&#xa;1 字节：时间戳扩展（高 8 位）。&#xa;3 字节：流 ID（通常为 0）。" style="text;whiteSpace=wrap;fontStyle=0;fontColor=#FF3333;" parent="1" vertex="1">
          <mxGeometry x="5235" y="-1621" width="330" height="100" as="geometry" />
        </mxCell>
        <mxCell id="gJWx8cU3EQOEuicg33ia-6" value="&lt;font color=&quot;#ff3333&quot;&gt;Header&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="5225" y="-1661" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="gJWx8cU3EQOEuicg33ia-7" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
          <mxGeometry x="5225" y="-1511" width="434.59" height="40" as="geometry" />
        </mxCell>
        <mxCell id="gJWx8cU3EQOEuicg33ia-8" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
          <mxGeometry x="5677" y="-1745.33" width="404.2" height="274.33" as="geometry" />
        </mxCell>
        <mxCell id="4ehvYs4uBC59rccrSoze-6" value="Signature" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="4135" y="-1871.3600000000001" width="186" height="30" as="geometry" />
        </mxCell>
        <mxCell id="4ehvYs4uBC59rccrSoze-7" value="Version" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="4320" y="-1871.3600000000001" width="101" height="30" as="geometry" />
        </mxCell>
        <mxCell id="4ehvYs4uBC59rccrSoze-9" value="Flag" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="4421" y="-1871.3600000000001" width="90" height="30" as="geometry" />
        </mxCell>
