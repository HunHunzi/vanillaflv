        </mxCell>
        <mxCell id="sFTBbgv-1wokPd63pDNA-5" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;CompositionTime&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="4366" y="-495.24" width="404" height="35.24" as="geometry" />
        </mxCell>
        <mxCell id="sFTBbgv-1wokPd63pDNA-6" value="3Byte" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="4446" y="-524.36" width="50" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sFTBbgv-1wokPd63pDNA-7" value="&lt;table&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;table&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;高 4 位表示帧类型（Frame Type）&lt;br&gt;低 4 位表示视频编码类型（CodecID）&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="3835" y="-470" width="230" height="50" as="geometry" />
        </mxCell>
        <mxCell id="sFTBbgv-1wokPd63pDNA-8" value="AVC/H.264 专用字段，表示视频包类型：&lt;br&gt; - &lt;code&gt;0&lt;/code&gt;：AVC Sequence Header （包含&amp;nbsp;&lt;strong&gt;SPS（序列参数集）&lt;/strong&gt; 和 &lt;strong&gt;PPS（图像参数集&lt;/strong&gt;）&lt;br&gt; - &lt;code&gt;1&lt;/code&gt;：NALU 数据（正常帧数据）&lt;br&gt; - &lt;code&gt;2&lt;/code&gt;：AVC End of Sequence（流结束标记，几乎不用）。" style="text;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="4185" y="-430" width="330" height="80" as="geometry" />
        </mxCell>
        <mxCell id="sFTBbgv-1wokPd63pDNA-9" value="对 H.264 视频数据的时间戳调整，单位是毫秒。&lt;br&gt;用于表示解码时间戳（DTS）与显示时间戳（PTS）之间的差值。" style="text;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="4496" y="-454.36" width="560" height="50" as="geometry" />
        </mxCell>
        <mxCell id="sFTBbgv-1wokPd63pDNA-10" value="视频帧数据：&lt;br&gt; - 如果是 AVC Sequence Header，则为配置数据（SPS 和 PPS）。&lt;br&gt; - 如果是 NALU 数据，则为一个或多个 H.264 NALU 单元。" style="text;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="4970" y="-454.36" width="390" height="70" as="geometry" />
        </mxCell>
        <mxCell id="sFTBbgv-1wokPd63pDNA-11" value="&lt;p style=&quot;text-align: left;&quot;&gt;Frame Type（高 4 位）：帧的类型，表示这段数据属于哪种视频帧。&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;1：关键帧（Keyframe）。&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;2：中间帧（Interframe）。&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;3：可丢弃的中间帧（Disposable Interframe）。&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;4：生成的关键帧（Generated Keyframe，几乎不用）。&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;5：视频命令帧（Video Info/Command Frame）。&lt;/p&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="3600" y="-400" width="390" height="200" as="geometry" />
        </mxCell>
        <mxCell id="sFTBbgv-1wokPd63pDNA-12" value="CodecID（低 4 位）：视频编码格式的类型。&#xa;2：Sorenson H.263。&#xa;3：Screen Video。&#xa;4：On2 VP6。&#xa;5：On2 VP6 with Alpha。&#xa;6：Screen Video v2。&#xa;7：AVC (H.264)。" style="text;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="3615" y="-213.62" width="270" height="120" as="geometry" />
        </mxCell>
        <mxCell id="sFTBbgv-1wokPd63pDNA-13" value="AVCPacketType&lt;br&gt;当 CodecID 为 7（即 H.264）时，这个字段表示 H.264 数据包的类型：&lt;br&gt;0：AVC Sequence Header（AVC 解码器配置，包含 SPS 和 PPS）。&lt;br&gt;1：NALU 数据（正常帧数据）。&lt;br&gt;2：AVC End of Sequence（流结束标记，几乎不用）。&lt;div&gt;&lt;br/&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="4028" y="-334.8" width="400" height="100" as="geometry" />
        </mxCell>
        <mxCell id="sFTBbgv-1wokPd63pDNA-14" value="&lt;span style=&quot;color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; background-color: rgb(251, 251, 251); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&quot;&gt;CompositionTime&lt;/span&gt;&lt;br style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; background-color: rgb(251, 251, 251); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; background-color: rgb(251, 251, 251); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&quot;&gt;用于计算显示时间戳（PTS）：&lt;/span&gt;&lt;br style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; background-color: rgb(251, 251, 251); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; background-color: rgb(251, 251, 251); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&quot;&gt;CompositionTime = PTS - DTS。&lt;/span&gt;&lt;br style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; background-color: rgb(251, 251, 251); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; background-color: rgb(251, 251, 251); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&quot;&gt;为 3 字节有符号整数，大端字节序。&lt;/span&gt;&lt;br style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; background-color: rgb(251, 251, 251); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; background-color: rgb(251, 251, 251); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&quot;&gt;如果 AVCPacketType 为 0（AVC Sequence Header），这个字段为 0。&lt;/span&gt;" style="text;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="4500" y="-404.36" width="410" height="100" as="geometry" />
        </mxCell>
